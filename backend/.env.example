FLASK_ENV=development
SECRET_KEY=change-me

# Used to sign API JWTs. Must be set in production.
JWT_SECRET=dev-jwt-secret-change-me
JWT_TTL_DAYS=30
# OTP delivery: when true, the generated OTP is echoed back in the request-otp response
# (dev convenience). MUST be false in production — production sends OTP via WhatsApp.
OTP_ECHO_IN_RESPONSE=true

WHATSAPP_VERIFY_TOKEN=set-a-long-random-string
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_BASE=https://graph.facebook.com/v20.0
# Meta App Secret used to sign webhook payloads. If empty, signature check is skipped (dev only).
META_APP_SECRET=

DIALOGFLOW_PROJECT_ID=
DIALOGFLOW_LANGUAGE_CODE=en
GOOGLE_APPLICATION_CREDENTIALS=

FIRESTORE_PROJECT_ID=
FIRESTORE_EMULATOR_HOST=

CHATBOT_FALLBACK_CONTACT=Please contact the Student Affairs office at studentaffairs@university.edu
CHATBOT_CONFIDENCE_THRESHOLD=0.6

# NLP backend: dialogflow (default), gemma (local Ollama), gemini (Google AI),
# or openrouter/openai (OpenRouter — OpenAI-compatible gateway).
CHATBOT_NLP_BACKEND=dialogflow
# Required when CHATBOT_NLP_BACKEND=gemini. Get a key from
# https://aistudio.google.com/apikey (or Vertex AI Express).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# Optional: override the system prompt sent to Gemini.
# GEMINI_SYSTEM_INSTRUCTION=

# Required when CHATBOT_NLP_BACKEND=openrouter. Get a key from
# https://openrouter.ai/keys (looks like sk-or-v1-...).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional: override the system prompt sent to the model.
# OPENROUTER_SYSTEM_INSTRUCTION=

# Firebase Cloud Messaging — when both are unset, push is no-op.
FCM_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS above is shared with Dialogflow/Firestore; the
# service account must have roles/cloudmessaging.viewer + sendMessages access.

# WhatsApp number students send messages to. Used in the mobile app's share/
# invite text. Format: international without "+", e.g. 233244111222.
WHATSAPP_BOT_NUMBER=233000000000

# OTP delivery channel: "sms" (Hubtel), "whatsapp" (Meta template), or "both".
OTP_DELIVERY_CHANNEL=sms

# Meta-approved Authentication template that delivers the OTP. Create it in
# Meta Business Manager → WhatsApp Manager → Message templates with category
# "Authentication" and a single {{1}} body parameter for the code. Used when
# OTP_DELIVERY_CHANNEL includes "whatsapp".
WHATSAPP_OTP_TEMPLATE=otp_code
WHATSAPP_OTP_LANGUAGE=en

# Hubtel SMS (used for OTP delivery). Get credentials at:
# https://unity.hubtel.com → API Keys. SENDER_ID must be ≤11 chars and
# pre-approved in your Hubtel dashboard.
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
HUBTEL_SENDER_ID=

# Agora — Chat + RTC voice/video + RTM signalling.
# Get from https://console.agora.io. App Certificate is the HMAC key for all
# server-minted tokens; NEVER ship it to a client.
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_CHAT_APP_KEY=
# Workaround for hosting UIs that strip `#` from env var values (looking at
# you, Render). When AGORA_CHAT_ORG_NAME and AGORA_CHAT_APP_NAME are both
# set, they're combined as "<org>#<app>" and override AGORA_CHAT_APP_KEY.
AGORA_CHAT_ORG_NAME=
AGORA_CHAT_APP_NAME=
AGORA_CHAT_REST_HOST=
AGORA_CHAT_APP_TOKEN=
# Shared secret for Agora Chat Post-Send Callback signature verification.
# Configure the same value in Console → Chat → Callback Settings. Leave empty
# in dev only — signature check is skipped, never deploy that way.
AGORA_CHAT_WEBHOOK_SECRET=
